---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio — Kerehama Andrews',
  description = 'Websites, awards, and photography by Kerehama Andrews.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  </head>
  <body>
    <nav>
      <a href="https://kerehama.nz" class="brand">kerehama.nz</a>
      <div class="nav-controls">
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <div class="theme-icon">
            <div class="sun-icon">
              <div class="sun-center"></div>
              <div class="sun-rays">
                <div class="ray" style="--i: 0"></div>
                <div class="ray" style="--i: 1"></div>
                <div class="ray" style="--i: 2"></div>
                <div class="ray" style="--i: 3"></div>
                <div class="ray" style="--i: 4"></div>
                <div class="ray" style="--i: 5"></div>
                <div class="ray" style="--i: 6"></div>
                <div class="ray" style="--i: 7"></div>
              </div>
            </div>
            <div class="moon-icon">
              <div class="moon-shape"></div>
            </div>
          </div>
        </button>
        <div class="starmap-wrapper">
          <button class="starmap-toggle" aria-expanded="false" aria-controls="starmap-panel" aria-label="Site map">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><circle cx="18" cy="18" r="2"/>
              <line x1="6" y1="6" x2="18" y2="6"/><line x1="6" y1="6" x2="12" y2="18"/><line x1="18" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
          <div class="starmap" id="starmap-panel" aria-label="Site map">
            <svg viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg">
              <!-- Lines from portfolio hub to subdomains (top row) -->
              <line x1="150" y1="80" x2="50" y2="30" class="starmap-line" />
              <line x1="150" y1="80" x2="150" y2="30" class="starmap-line" />
              <line x1="150" y1="80" x2="250" y2="30" class="starmap-line" />

              <!-- Lines from portfolio hub to sections (bottom row) -->
              <line x1="150" y1="80" x2="50" y2="140" class="starmap-line" />
              <line x1="150" y1="80" x2="150" y2="140" class="starmap-line" />
              <line x1="150" y1="80" x2="250" y2="140" class="starmap-line" />

              <!-- Top row: subdomains -->
              <a href="https://kerehama.nz" target="_blank" rel="noopener noreferrer">
                <circle cx="50" cy="30" r="6" class="starmap-dot" />
                <text x="50" y="18" class="starmap-label">kerehama.nz</text>
              </a>
              <a href="https://lab.kerehama.nz" target="_blank" rel="noopener noreferrer">
                <circle cx="150" cy="30" r="6" class="starmap-dot" />
                <text x="150" y="18" class="starmap-label">lab</text>
              </a>
              <a href="https://notes.kerehama.nz" target="_blank" rel="noopener noreferrer">
                <circle cx="250" cy="30" r="6" class="starmap-dot" />
                <text x="250" y="18" class="starmap-label">notes</text>
              </a>

              <!-- Center: portfolio home -->
              <a href="#">
                <circle cx="150" cy="80" r="9" class="starmap-dot starmap-home" />
                <text x="150" y="68" class="starmap-label starmap-label-home">portfolio</text>
              </a>

              <!-- Bottom row: page sections -->
              <a href="#websites">
                <circle cx="50" cy="140" r="5" class="starmap-dot" />
                <text x="50" y="158" class="starmap-label">websites</text>
              </a>
              <a href="#awards">
                <circle cx="150" cy="140" r="5" class="starmap-dot" />
                <text x="150" y="158" class="starmap-label">awards</text>
              </a>
              <a href="#photos">
                <circle cx="250" cy="140" r="5" class="starmap-dot" />
                <text x="250" y="158" class="starmap-label">photos</text>
              </a>
            </svg>
          </div>
        </div>
      </div>
    </nav>

    <script>
      const btn = document.querySelector('.starmap-toggle');
      const panel = document.getElementById('starmap-panel');
      const btnIcon = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><line x1="6" y1="6" x2="18" y2="6"/><line x1="6" y1="6" x2="12" y2="18"/><line x1="18" y1="6" x2="18" y2="18"/></svg>`;
      function closePanel() {
        panel?.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
        if (btn) btn.innerHTML = btnIcon;
      }

      btn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = panel!.classList.toggle('open');
        btn!.setAttribute('aria-expanded', String(open));
        btn!.innerHTML = open ? '✕' : btnIcon;
      });

      // Close panel on outside click
      document.addEventListener('click', (e) => {
        const target = e.target as Element;
        if (!target.closest('.starmap-wrapper')) {
          closePanel();
        }
      });

      // Close panel when any link inside is clicked
      panel?.addEventListener('click', (e) => {
        const target = e.target as Element;
        const link = target.closest('a');
        if (!link) return;

        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          closePanel();
          const el = document.querySelector(href);
          if (el) el.scrollIntoView({ behavior: 'smooth' });
        } else {
          // External link — just close the panel, let the browser handle navigation
          closePanel();
        }
      });
    </script>

    <main>
      <slot />
    </main>

    <footer>
      Built and updated by Miles · Powered by Astro · {new Date().getFullYear()}
    </footer>

    <script>
      const themeToggle = document.getElementById('theme-toggle');
      const root = document.documentElement;
      const savedTheme = localStorage.getItem('theme') || 'dark';
      root.setAttribute('data-theme', savedTheme);

      themeToggle?.addEventListener('click', () => {
        const currentTheme = root.getAttribute('data-theme');
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        document.body.classList.add('theme-transitioning');

        if (newTheme === 'light') {
          themeToggle.classList.add('contracting');
          setTimeout(() => { root.setAttribute('data-theme', newTheme); }, 100);
          setTimeout(() => {
            themeToggle.classList.remove('contracting');
            setTimeout(() => { document.body.classList.remove('theme-transitioning'); }, 500);
          }, 600);
        } else {
          themeToggle.classList.add('expanding');
          setTimeout(() => {
            root.setAttribute('data-theme', newTheme);
            setTimeout(() => {
              themeToggle.classList.remove('expanding');
              setTimeout(() => { document.body.classList.remove('theme-transitioning'); }, 500);
            }, 500);
          }, 200);
        }
        localStorage.setItem('theme', newTheme);
      });
    </script>
  </body>
</html>
